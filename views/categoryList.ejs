<!DOCTYPE html>
<html lang="en">
  <%- include("./partials/htmlhead.ejs") %>
  <body>
    <main class="page-shell">
      <%- include("./partials/header.ejs") %>
      <section class="page-section">
        <div class="section-heading">
          <p class="section-kicker">Organization</p>
          <h2>Category List</h2>
        </div>
        <% if(list.length === 0) { %>
          <div class="empty-state">
            <h3>Category list is empty</h3>
            <p>Create a category to group your products more clearly.</p>
          </div>
        <% } else{ %>
          <div class="simple-list">
            <% list.forEach((item) =>{ %>
              <article class="list-row">
                <h3><%= item.categoryname %></h3>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>
  </body>
</html>
